<!DOCTYPE html>
<html lang="ur" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ChatBot Interface</title>

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Sora:wght@300;400;500;600&display=swap" rel="stylesheet"/>

  <!-- External CSS -->
  <link rel="stylesheet" href="style.css"/>
</head>
<body>

<div class="app">

  <!-- ===== SIDEBAR ===== -->
  <aside class="sidebar">

    <!-- Logo -->
    <div class="sidebar-logo">
      <div class="logo-icon">🤖</div>
      <span class="logo-text">ChatBot UI</span>
    </div>

    <!-- New Chat Button -->
    <button class="new-chat-btn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
        <line x1="12" y1="5" x2="12" y2="19"/>
        <line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Nai Baat Cheet
    </button>

    <!-- Today's Chats -->
    <div class="section-label">Aaj</div>

    <div class="chat-item active">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      Python mein loop kaisay likhein
    </div>

    <div class="chat-item">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      JavaScript variables explain karo
    </div>

    <!-- This Week's Chats -->
    <div class="section-label">Is Hafte</div>

    <div class="chat-item">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      HTML form banana sikho
    </div>

    <div class="chat-item">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      CSS flexbox tutorial
    </div>

    <div class="chat-item">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      React components kya hain
    </div>

    <!-- Older Chats -->
    <div class="section-label">Pehle</div>

    <div class="chat-item">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      API integration guide
    </div>

    <div class="chat-item">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      Database design principles
    </div>

    <!-- Footer Buttons -->
    <div class="sidebar-footer">
      <div class="footer-btn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="3"/>
          <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
        </svg>
        Settings
      </div>
      <div class="footer-btn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
        Account
      </div>
    </div>

  </aside>

  <!-- ===== MAIN AREA ===== -->
  <main class="main">

    <!-- Top Bar -->
    <div class="topbar">
      <div class="model-selector">
        <div class="model-dot"></div>
        <span>GPT-4o</span>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="opacity:.5">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>

      <div class="topbar-actions">
        <div class="icon-btn" title="Share">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
          </svg>
        </div>
        <div class="icon-btn" title="Edit">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Messages Area -->
    <div class="messages-wrap" id="messages-wrap">
      <div class="msg-group" id="msg-group">

        <!-- Welcome Screen -->
        <div class="welcome" id="welcome-screen">
          <div class="welcome-icon">🤖</div>
          <h1>Aaj main aapki kya madad kar sakta hoon?</h1>
          <p>Koi bhi sawal poochein — coding, writing, analysis, ya kuch bhi aur!</p>

          <div class="suggestion-grid">
            <div class="suggestion-card" onclick="fillInput('Python mein loop kaisay likhein?')">
              <strong>💻 Coding Sikhein</strong>
              Python mein loop kaisay likhein?
            </div>
            <div class="suggestion-card" onclick="fillInput('Meri email professional banao')">
              <strong>✉️ Writing Mein Madad</strong>
              Meri email professional banao
            </div>
            <div class="suggestion-card" onclick="fillInput('JavaScript aur Python mein kya farq hai?')">
              <strong>🔍 Compare Karein</strong>
              JavaScript vs Python farq
            </div>
            <div class="suggestion-card" onclick="fillInput('CSS flexbox kaisay kaam karta hai?')">
              <strong>🎨 Design Seekhein</strong>
              CSS flexbox kaisay kaam karta hai?
            </div>
          </div>
        </div>

        <!-- Conversation Messages (JS se dynamically add hoti hain) -->
        <div id="conversation" style="display:none; flex-direction:column; gap:20px;"></div>

      </div>
    </div>

    <!-- Input Area -->
    <div class="input-area">
      <div class="input-box">

        <!-- Attach Button -->
        <button class="attach-btn" title="File attach karein">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/>
          </svg>
        </button>

        <!-- Text Input -->
        <textarea id="msg-input" rows="1" placeholder="Koi bhi sawal poochein..."></textarea>

        <!-- Send Button -->
        <button class="send-btn" id="send-btn" title="Bhejein">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>

      </div>
      <div class="input-footer">ChatBot galtiyan kar sakta hai. Zaroori faislon mein verify zaroor karein.</div>
    </div>

  </main>
</div>

<!-- External JavaScript -->
<script src="script.js"></script>

</body>
</html>
